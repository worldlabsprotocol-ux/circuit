import React, { useState } from "react";
import { Buffer } from "buffer";
window.Buffer = Buffer;

import Starfield from "./components/Starfield";

import Home from "./pages/Home";
import Create from "./pages/Create";
import Royalties from "./pages/Royalties";
import Mix from "./pages/Mix";

function App() {
  const [activeTab, setActiveTab] = useState("Create");

  return (
    <div style={{ position: "relative", minHeight: "100vh", overflow: "hidden" }}>
      
      {/* GLOBAL STARFIELD */}
      <Starfield />

      {/* CONTENT LAYER */}
      <div style={{ position: "relative", zIndex: 2, color: "#0ff" }}>
        
        <header style={{ padding: "2rem", textAlign: "center" }}>
          <h1 style={{ fontSize: "3rem" }}>CIRCUIT</h1>
        </header>

        <main style={{ padding: "1rem", paddingBottom: "5rem" }}>
          {activeTab === "Home" && <Home />}
          {activeTab === "Create" && <Create />}
          {activeTab === "Royalties" && <Royalties />}
          {activeTab === "Mix" && <Mix />}
        </main>

        <nav style={{
          position: "fixed",
          bottom: 0,
          left: 0,
          right: 0,
          background: "rgba(0,0,0,0.8)",
          display: "flex",
          justifyContent: "space-around",
          padding: "1rem"
        }}>
          {["Home","Create","Microphone","Royalties","Mix"].map(tab => (
            <button
              key={tab}
              onClick={() => setActiveTab(tab)}
              style={{
                background: activeTab === tab ? "#0ff" : "#111",
                color: activeTab === tab ? "#000" : "#0ff",
                padding: "0.5rem 1rem",
                borderRadius: "20px",
                border: "none"
              }}
            >
              {tab}
            </button>
          ))}
        </nav>

      </div>
    </div>
  );
}

export default App;
