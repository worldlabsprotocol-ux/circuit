import React, { useState } from 'react';
import { Buffer } from 'buffer';
window.Buffer = Buffer;

import Home from './pages/Home';
import Create from './pages/Create';
import Mic from './pages/Mic';
import Royalties from './pages/Royalties';
import Mix from './pages/Mix';

function App() {
  const [activeTab, setActiveTab] = useState('Create');

  return (
    <div style={{ background: '#000', color: '#0ff', minHeight: '100vh', display: 'flex', flexDirection: 'column' }}>

      {/* HEADER */}
      <header style={{ padding: '2rem', textAlign: 'center' }}>
        <h1 style={{ fontSize: '3rem', letterSpacing: '2px' }}>CIRCUIT</h1>
        <button style={{ marginTop: '1rem', padding: '0.75rem 2rem', background: '#7e22ce', color: '#fff', border: 'none', borderRadius: '30px' }}>
