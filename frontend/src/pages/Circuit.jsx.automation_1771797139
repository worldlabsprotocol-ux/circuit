import { exportWav, exportMp3 } from "../utils/audioExport";
import { useState, useEffect, useRef } from "react"
import LoopBrowser from "../components/LoopBrowser"
import { loadSample, playSample } from "../audio/SimpleSampler"

function createInitialTracks() {
  return Array.from({ length: 8 }, () => ({
    pattern: Array(16).fill(false),
    buffer: null
  }))
}

export default function Circuit() {

  const [tracks, setTracks] = useState(createInitialTracks())
  const [history, setHistory] = useState([])
  const [future, setFuture] = useState([])

  const [bpm, setBpm] = useState(120)
  const [isPlaying, setIsPlaying] = useState(false)
  const [metronomeOn, setMetronomeOn] = useState(false)
  const [currentStep, setCurrentStep] = useState(0)

  const intervalRef = useRef(null)

  const pushHistory = (newState) => {
    setHistory(prev => [...prev, tracks])
    setFuture([])
    setTracks(newState)
  }

  const undo = () => {
    if (history.length === 0) return
    const previous = history[history.length - 1]
    setFuture(prev => [tracks, ...prev])
    setTracks(previous)
    setHistory(prev => prev.slice(0, -1))
  }

  const redo = () => {
    if (future.length === 0) return
    const next = future[0]
    setHistory(prev => [...prev, tracks])
    setTracks(next)
    setFuture(prev => prev.slice(1))
  }

  const toggleStep = (trackIndex, stepIndex) => {
    const updated = tracks.map((track, tIndex) => {
      if (tIndex !== trackIndex) return track
      return {
        ...track,
        pattern: track.pattern.map((step, sIndex) =>
          sIndex === stepIndex ? !step : step
        )
      }
    })
    pushHistory(updated)
  }

  const assignSampleToTrack = async (sample) => {
    const buffer = await loadSample(sample.file)
    const updated = tracks.map((track, index) =>
      index === 0 ? { ...track, buffer } : track
    )
    pushHistory(updated)
  }

  const playStep = (stepIndex) => {
    tracks.forEach(track => {
      if (track.pattern[stepIndex] && track.buffer) {
        playSample(track.buffer)
      }
    })

    if (metronomeOn && stepIndex % 4 === 0) {
      const click = new AudioContext()
      const osc = click.createOscillator()
      osc.frequency.value = 1000
      osc.connect(click.destination)
      osc.start()
      osc.stop(click.currentTime + 0.05)
    }
  }

  useEffect(() => {
    if (!isPlaying) {
      clearInterval(intervalRef.current)
      return
    }

    const intervalTime = (60 / bpm) * 1000 / 4

    intervalRef.current = setInterval(() => {
      setCurrentStep(prev => {
        const next = (prev + 1) % 16
        playStep(next)
        return next
      })
    }, intervalTime)

    return () => clearInterval(intervalRef.current)

  }, [isPlaying, bpm, tracks, metronomeOn])

  const moveTrack = (fromIndex, toIndex) => {
    if (fromIndex === toIndex) return
    if (toIndex < 0 || toIndex >= tracks.length) return

    const next = [...tracks]
    const [moved] = next.splice(fromIndex, 1)
    next.splice(toIndex, 0, moved)
    pushHistory(next)
  }

  const onDragStart = (e, index) => {
    e.dataTransfer.setData("text/plain", String(index))
    e.dataTransfer.effectAllowed = "move"
  }

  const onDragOver = (e) => {
    e.preventDefault()
    e.dataTransfer.dropEffect = "move"
  }

  const onDrop = (e, toIndex) => {
    e.preventDefault()
    const fromIndex = Number(e.dataTransfer.getData("text/plain"))
    if (Number.isNaN(fromIndex)) return
    moveTrack(fromIndex, toIndex)
  }

  return (
    <div style={{ display: "flex" }}>
      <LoopBrowser onAssign={assignSampleToTrack} />

      <div style={{ flex: 1, padding: 20 }}>
        <h2 style={{ color: "#0ff" }}>Create</h2>

        <div style={{ marginBottom: 20 }}>
          <button onClick={() => setIsPlaying(!isPlaying)}>
            {isPlaying ? "Stop" : "Play"}
          </button>

          <button onClick={undo} style={{ marginLeft: 10 }}>Undo</button>
          <button onClick={redo} style={{ marginLeft: 10 }}>Redo</button>

          <button onClick={() => setMetronomeOn(!metronomeOn)} style={{ marginLeft: 10 }}>
            Metronome: {metronomeOn ? "On" : "Off"}
          </button>

          <div style={{ marginTop: 10 }}>
          <div style={{ marginTop: 10 }}>
            <button onClick={() => exportWav(new AudioContext().createBuffer(1, 44100 * 2, 44100))}>Export WAV</button>
            <button style={{ marginLeft: 10 }} onClick={() => exportMp3(new AudioContext().createBuffer(1, 44100 * 2, 44100))}>Export MP3</button>
            <button style={{ marginLeft: 10 }} onClick={() => alert("IPFS upload hook coming next")}>Share</button>
          </div>
            BPM: {bpm}
            <input
              type="range"
              min="60"
              max="180"
              value={bpm}
              onChange={(e) => setBpm(Number(e.target.value))}
              style={{ marginLeft: 10 }}
            />
          </div>
        </div>

        <div style={{ maxHeight: 520, overflowY: "auto", paddingRight: 10 }}>
          {tracks.map((track, tIndex) => (
            <div
              key={tIndex}
              draggable
              onDragStart={(e) => onDragStart(e, tIndex)}
              onDragOver={onDragOver}
              onDrop={(e) => onDrop(e, tIndex)}
              style={{
                margin: "10px 0",
                padding: 10,
                borderRadius: 10,
                border: "1px solid rgba(0,255,255,0.25)",
                background: "rgba(0,0,0,0.35)",
                cursor: "grab"
              }}
            >
              <div style={{ display: "flex", alignItems: "center", marginBottom: 8 }}>
                <span style={{ color: "#0ff", marginRight: 10 }}>
                  Track {tIndex + 1}
                </span>

                <span style={{ color: "rgba(0,255,255,0.6)", fontSize: 12 }}>
                  Drag to reorder
                </span>
              </div>

              <div>
                {track.pattern.map((step, sIndex) => (
                  <span
                    key={sIndex}
                    onClick={() => toggleStep(tIndex, sIndex)}
                    style={{
                      display: "inline-block",
                      width: 25,
                      height: 25,
                      margin: 4,
                      background: step
                        ? (sIndex === currentStep ? "#fff" : "#0ff")
                        : "#222",
                      borderRadius: 6,
                      cursor: "pointer"
                    }}
                  />
                ))}
              </div>
            </div>
          ))}
        </div>

      </div>
    </div>
  )
}
