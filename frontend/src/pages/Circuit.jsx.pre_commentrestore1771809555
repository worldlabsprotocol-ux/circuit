import { useState, useEffect } from "react"
import LoopBrowser from "../components/LoopBrowser"
import EffectsRack from "../components/EffectsRack"
import CommentSection from "../components/CommentSection"

export default function Circuit() {

  const [tracks, setTracks] = useState([
    { id: 1, name: "Kick", pattern: Array(16).fill(false) },
    { id: 2, name: "Snare", pattern: Array(16).fill(false) },
    { id: 3, name: "HiHat", pattern: Array(16).fill(false) },
  ])

  function toggleStep(trackIndex, stepIndex) {
    const updated = [...tracks]
    updated[trackIndex].pattern[stepIndex] =
      !updated[trackIndex].pattern[stepIndex]
    setTracks(updated)
  }

  return (
    <div style={{ padding: "40px" }}>

      <h2 style={{ marginBottom: "20px" }}>Create</h2>

      {tracks.map((track, tIndex) => (
        <div key={track.id} style={{ marginBottom: "12px" }}>
          <div style={{ marginBottom: "4px" }}>{track.name}</div>
          <div style={{ display: "flex", gap: "6px" }}>
            {track.pattern.map((step, sIndex) => (
              <div
                key={sIndex}
                onClick={() => toggleStep(tIndex, sIndex)}
                style={{
                  width: "24px",
                  height: "24px",
                  background: step ? "#0ff" : "#111",
                  border: "1px solid #0ff",
                  cursor: "pointer"
                }}
              />
            ))}
          </div>
        </div>
      ))}

      <LoopBrowser />
      <EffectsRack />

      <CommentSection sessionId="circuit-session" />

    </div>
  )
}
