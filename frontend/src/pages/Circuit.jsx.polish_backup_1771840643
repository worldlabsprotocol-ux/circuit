import { useState } from "react"

export default function Circuit() {
  const [bpm, setBpm] = useState(120)
  const [tracks, setTracks] = useState(
    Array.from({ length: 8 }, () =>
      Array.from({ length: 16 }, () => false)
    )
  )

  function toggleCell(trackIndex, stepIndex) {
    const updated = tracks.map((track, tIdx) =>
      tIdx === trackIndex
        ? track.map((step, sIdx) =>
            sIdx === stepIndex ? !step : step
          )
        : track
    )
    setTracks(updated)
  }

  function playBeat() {
    console.log("Play logic here")
  }

  function exportWav() {
    alert("Export WAV coming")
  }

  function exportMp3() {
    alert("Export MP3 coming")
  }

  function shareBeat() {
    alert("Share coming")
  }

  function remixThis() {
    alert("Remix logic coming")
  }

  return (
    <div style={{ padding: 40 }}>

      <h2>Create</h2>

      <div style={{ marginBottom: 20 }}>
        <button onClick={playBeat}>Play</button>
        <button onClick={exportWav} style={{ marginLeft: 10 }}>Export WAV</button>
        <button onClick={exportMp3} style={{ marginLeft: 10 }}>Export MP3</button>
        <button onClick={shareBeat} style={{ marginLeft: 10 }}>Share</button>
        <button onClick={remixThis} style={{ marginLeft: 10 }}>Remix This</button>
      </div>

      <div style={{ marginBottom: 20 }}>
        BPM: {bpm}
        <input
          type="range"
          min="60"
          max="180"
          value={bpm}
          onChange={(e) => setBpm(parseInt(e.target.value))}
          style={{ marginLeft: 10 }}
        />
      </div>

      {tracks.map((track, trackIndex) => (
        <div key={trackIndex} style={{ marginBottom: 10 }}>
          <strong>Track {trackIndex + 1}</strong>
          <div style={{ display: "flex", marginTop: 5 }}>
            {track.map((step, stepIndex) => (
              <div
                key={stepIndex}
                onClick={() => toggleCell(trackIndex, stepIndex)}
                style={{
                  width: 24,
                  height: 24,
                  marginRight: 4,
                  background: step ? "#00ffff" : "#333",
                  borderRadius: 4,
                  cursor: "pointer"
                }}
              />
            ))}
          </div>
        </div>
      ))}

    </div>
  )
}
