import React, { useState } from "react"
import LoopBrowser from "../components/LoopBrowser"
import EffectsRack from "../components/EffectsRack"
import CommentSection from "../components/CommentSection"

export default function Circuit() {
  const [bpm, setBpm] = useState(120)
  const [distributionStatus, setDistributionStatus] = useState(null)

  const tracks = Array.from({ length: 8 }, () =>
    Array.from({ length: 16 }, () => false)
  )

  function exportWav() {
    alert("Export WAV coming")
  }

  function handleDistribute() {
    setDistributionStatus("Uploading to distribution...")
    setTimeout(() => {
      setDistributionStatus("Pending distribution to Spotify / Apple")
    }, 1500)
  }

  return (
    <div style={{ padding: 20 }}>

      <h2 style={{ fontSize: 28, marginBottom: 20 }}>Create</h2>

      {/* BPM */}
      <div style={{ marginBottom: 20 }}>
        <label>BPM: {bpm}</label>
        <input
          type="range"
          min="60"
          max="180"
          value={bpm}
          onChange={(e) => setBpm(parseInt(e.target.value))}
          style={{ width: "100%" }}
        />
      </div>

      {/* Beat Grid */}
      <div style={{ marginBottom: 30 }}>
        {tracks.map((row, rowIndex) => (
          <div key={rowIndex} style={{ display: "flex", marginBottom: 4 }}>
            {row.map((cell, colIndex) => (
              <div
                key={colIndex}
                style={{
                  width: 28,
                  height: 28,
                  marginRight: 4,
                  background: "#111",
                  border: "1px solid #00ffff33",
                  borderRadius: 4
                }}
              />
            ))}
          </div>
        ))}
      </div>

      {/* Export Controls */}
      <div style={{ marginBottom: 20 }}>
        <button onClick={exportWav}>Export WAV</button>

        <button
          onClick={handleDistribute}
          style={{ marginLeft: 10 }}
        >
          Distribute Track
        </button>

        {distributionStatus && (
          <div style={{ marginTop: 10, color: "#00ffff" }}>
            {distributionStatus}
          </div>
        )}
      </div>

      {/* Effects Rack */}
      <EffectsRack />

      {/* Loop Browser */}
      <LoopBrowser />

      {/* Comments */}
      <CommentSection sessionId="circuit-session" />

    </div>
  )
}
